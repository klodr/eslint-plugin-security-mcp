{
  "name": "eslint-plugin-security-mcp",
  "version": "0.2.0",
  "description": "ESLint rules to detect prompt-injection vectors in Model Context Protocol server code",
  "license": "Apache-2.0",
  "author": "klodr",
  "homepage": "https://github.com/klodr/eslint-plugin-security-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/klodr/eslint-plugin-security-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/klodr/eslint-plugin-security-mcp/issues"
  },
  "type": "commonjs",
  "main": "src/index.js",
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src/",
    "LICENSE",
    "NOTICE",
    "README.md"
  ],
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "mcp",
    "model-context-protocol",
    "security",
    "prompt-injection",
    "llm",
    "base64",
    "unicode"
  ],
  "scripts": {
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.{js,mjs,cjs}": [
      "eslint --max-warnings=0 --no-warn-ignored"
    ],
    "*.{yml,yaml}": [
      "yamllint"
    ],
    "*.md": [
      "markdownlint-cli2"
    ]
  },
  "peerDependencies": {
    "eslint": ">=10.3.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.0",
    "@commitlint/config-conventional": "^21.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "fast-check": "^4.7.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.4",
    "lockfile-lint": "^5.0.0",
    "markdownlint-cli2": "^0.22.1",
    "vitest": "^4.1.5",
    "yaml-lint": "^1.7.0"
  },
  "engines": {
    "node": ">=22.22.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
